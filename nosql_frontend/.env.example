# API Settings
NEXT_PUBLIC_API_URL=http://localhost:5000/api  # Base URL of the backend REST API
NEXT_PUBLIC_MONGO_API_URL=http://localhost:5000/api/rag # MongoDB/NoSQL backend URL (RAG pipeline)

# Supabase (Optional/Relational layer)
NEXT_PUBLIC_SUPABASE_URL=      # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Supabase public anon key

# App Settings
NEXT_PUBLIC_APP_NAME=SpotiRAG
NEXT_PUBLIC_ENV=development # development | production
